<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="4dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header chính: Dữ liệu đổ từ SQL -->
        <LinearLayout
            android:id="@+id/layout_header_clickable"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="4dp"
            android:background="#FFFFFF">

            <!-- STT -->
            <TextView android:id="@+id/txt_stt" android:layout_width="40dp" android:layout_height="wrap_content" android:gravity="center" android:textColor="#333"/>

            <!-- NĂM HỌC (Lấy từ SQL: SemesterCode) -->
            <TextView android:id="@+id/txt_year_item" android:layout_width="90dp" android:layout_height="wrap_content" android:gravity="center" android:textStyle="bold" android:textColor="#333"/>

            <!-- MÔN HỌC -->
            <TextView android:id="@+id/txt_subject_name" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="#555" android:paddingStart="8dp"/>

            <!-- ĐIỂM TRUNG BÌNH CẢ NĂM -->
            <TextView android:id="@+id/txt_avg_year" android:layout_width="70dp" android:layout_height="28dp" android:gravity="center"  android:textColor="#FFFFFF" android:textStyle="bold" android:layout_marginHorizontal="4dp"/>

            <!-- XÉT HỌC BẠ (Icon động) -->
            <TextView android:id="@+id/txt_status_icon" android:layout_width="60dp" android:layout_height="wrap_content" android:gravity="center" android:textSize="16sp"/>

            <!-- NÚT CHI TIẾT (Mũi tên hoặc Icon xem) -->
            <TextView android:id="@+id/btn_expand_icon" android:layout_width="50dp" android:layout_height="wrap_content" android:gravity="center" android:text="▼" android:textColor="#2563EB" android:textSize="18sp" />
        </LinearLayout>

        <!-- BẢNG CHI TIẾT: Hiện lên khi đổ dữ liệu -->
        <LinearLayout
            android:id="@+id/layout_subject_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F1F5F9"
            android:padding="1dp"
            android:visibility="gone">

            <TableLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:stretchColumns="*">
                <!-- Tiêu đề bảng chi tiết -->
                <TableRow android:background="#1F2937" android:padding="8dp">
                    <TextView android:text="Học kỳ" android:textColor="#FFF" android:gravity="center" android:textSize="11sp" android:textStyle="bold"/>
                    <TextView android:text="Thành phần" android:textColor="#FFF" android:gravity="center" android:textSize="11sp" android:textStyle="bold"/>
                    <TextView android:text="15p" android:textColor="#FFF" android:gravity="center" android:textSize="11sp" android:textStyle="bold"/>
                    <TextView android:text="Giữa kỳ" android:textColor="#FFF" android:gravity="center" android:textSize="11sp" android:textStyle="bold"/>
                    <TextView android:text="Cuối kỳ" android:textColor="#FFF" android:gravity="center" android:textSize="11sp" android:textStyle="bold"/>
                    <TextView android:text="TB học kỳ" android:textColor="#FFF" android:gravity="center" android:textSize="11sp" android:textStyle="bold"/>
                </TableRow>

                <!-- Dòng dữ liệu chi tiết (Đổ từ SQL) -->
                <TableRow android:background="#FFFFFF" android:padding="10dp">
                    <TextView android:id="@+id/txt_sem_name" android:gravity="center" android:textColor="#333" android:textSize="12sp"/>
                    <TextView android:id="@+id/txt_score_oral" android:gravity="center" android:textColor="#333" android:textSize="12sp"/>
                    <TextView android:id="@+id/txt_score_15m" android:gravity="center" android:textColor="#333" android:textSize="12sp"/>
                    <TextView android:id="@+id/txt_score_mid" android:gravity="center" android:textColor="#333" android:textSize="12sp"/>
                    <TextView android:id="@+id/txt_score_final" android:gravity="center" android:textColor="#333" android:textSize="12sp"/>
                    <TextView android:id="@+id/txt_score_sem_avg" android:gravity="center" android:textStyle="bold" android:textColor="#333" android:textSize="12sp"/>
                </TableRow>
            </TableLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>