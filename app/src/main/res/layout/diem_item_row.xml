<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:id="@+id/layout_header_clickable"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:background="@android:color/white"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="10dp">

            <TextView
                android:id="@+id/txt_stt"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="1"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txt_year_item"
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="2025-2026"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txt_subject_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Toán học" />

            <TextView
                android:id="@+id/txt_avg_year"
                android:layout_width="60dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_pill_green"
                android:gravity="center"
                android:text="9.3"
                android:textColor="@android:color/white"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/img_status_check"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="10dp"
                android:src="@android:drawable/checkbox_on_background"
                android:tint="#10B981" />

            <ImageView
                android:id="@+id/img_expand"
                android:layout_width="22dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:src="@android:drawable/arrow_down_float"
                android:tint="#2563EB" />

        </LinearLayout>

        <!-- DETAIL -->
        <LinearLayout
            android:id="@+id/layout_subject_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F9FAFB"
            android:orientation="vertical"
            android:visibility="gone">

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TableLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <!-- HEADER -->
                    <TableRow
                        android:background="#1F2937">

                        <TextView
                            android:padding="10dp"
                            android:text="Học kỳ"
                            android:textColor="@android:color/white"
                            android:textStyle="bold" />

                        <TextView
                            android:padding="10dp"
                            android:text="Điểm thành phần"
                            android:textColor="@android:color/white"
                            android:textStyle="bold" />

                        <TextView
                            android:padding="10dp"
                            android:text="15p"
                            android:textColor="@android:color/white"
                            android:textStyle="bold" />

                        <TextView
                            android:padding="10dp"
                            android:text="Giữa kỳ"
                            android:textColor="@android:color/white"
                            android:textStyle="bold" />

                        <TextView
                            android:padding="10dp"
                            android:text="Cuối kỳ"
                            android:textColor="@android:color/white"
                            android:textStyle="bold" />

                        <TextView
                            android:padding="10dp"
                            android:text="Cả năm"
                            android:textColor="@android:color/white"
                            android:textStyle="bold" />
                    </TableRow>

                    <!-- DATA -->
                    <TableRow
                        android:background="@android:color/white">

                        <TextView
                            android:id="@+id/txt_sem_name"
                            android:padding="10dp"
                            android:text="HK1" />

                        <TextView
                            android:id="@+id/txt_score_oral"
                            android:padding="10dp"
                            android:text="10,6,7" />

                        <TextView
                            android:id="@+id/txt_score_15m"
                            android:padding="10dp"
                            android:text="7,9" />

                        <TextView
                            android:id="@+id/txt_score_mid"
                            android:padding="10dp"
                            android:text="9" />

                        <TextView
                            android:id="@+id/txt_score_final"
                            android:padding="10dp"
                            android:text="10" />

                        <TextView
                            android:id="@+id/txt_score_sem_avg"
                            android:padding="10dp"
                            android:text="9.3"
                            android:textStyle="bold" />
                    </TableRow>

                </TableLayout>

            </HorizontalScrollView>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>