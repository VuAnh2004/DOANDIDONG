<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:id="@+id/layout_header_clickable"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:background="#FFFFFF"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <TextView
                android:id="@+id/txt_stt"
                android:layout_width="28dp"
                android:layout_height="wrap_content"
                android:text="1"
                android:textColor="#94A3B8"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Học kỳ -->
            <TextView
                android:id="@+id/txt_year_item"
                android:layout_width="58dp"
                android:layout_height="wrap_content"
                android:text="HK1"
                android:textColor="#1E293B"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Tên môn -->
            <TextView
                android:id="@+id/txt_subject_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingStart="12dp"
                android:text="2024-2025"
                android:textColor="#1E293B"
                android:textSize="16sp" />

            <!-- Điểm TB -->
            <TextView
                android:id="@+id/txt_avg_year"
                android:layout_width="62dp"
                android:layout_height="34dp"
                android:background="#10B981"
                android:gravity="center"
                android:text="9.3"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginHorizontal="8dp" />

            <!-- Status Icon (ImageView) -->
            <ImageView
                android:id="@+id/img_status_icon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/icontichxanh"
                android:contentDescription="Trạng thái" />
            <!-- Mũi tên expand -->
            <ImageView
                android:id="@+id/btn_expand_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/arrow_down_float"
                app:tint="#1E40AF"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <!-- Chi tiết -->
        <LinearLayout
            android:id="@+id/layout_subject_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F8FAFC"
            android:visibility="gone"
            android:padding="2dp">

            <TableLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stretchColumns="*">

                <TableRow android:background="#1F2937" android:paddingVertical="10dp">
                    <TextView style="@style/DiemTableHead" android:text="Học kỳ" />
                    <TextView style="@style/DiemTableHead" android:text="Thành phần" />
                    <TextView style="@style/DiemTableHead" android:text="15p" />
                    <TextView style="@style/DiemTableHead" android:text="Giữa kỳ" />
                    <TextView style="@style/DiemTableHead" android:text="Cuối kỳ" />
                    <TextView style="@style/DiemTableHead" android:text="TB học kỳ" />
                </TableRow>

                <TableRow android:background="#FFFFFF" android:paddingVertical="12dp" android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/txt_sem_name"
                        style="@style/DiemTableBody"
                        android:text="2025-2026" />

                    <TextView
                        android:id="@+id/txt_score_oral"
                        style="@style/DiemTableBody"
                        android:text="10, 6, 7" />

                    <TextView
                        android:id="@+id/txt_score_15m"
                        style="@style/DiemTableBody"
                        android:text="7, 9" />

                    <TextView
                        android:id="@+id/txt_score_mid"
                        style="@style/DiemTableBody"
                        android:text="9.0" />

                    <TextView
                        android:id="@+id/txt_score_final"
                        style="@style/DiemTableBody"
                        android:text="10.0" />

                    <TextView
                        android:id="@+id/txt_score_sem_avg"
                        style="@style/DiemTableBody"
                        android:text="9.3"
                        android:textStyle="bold"
                        android:textColor="#1E293B" />
                </TableRow>
            </TableLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>