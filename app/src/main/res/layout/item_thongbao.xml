<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="start">

        <!-- Avatar -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/img_sender_avatar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/anhuser"
            app:civ_border_width="1dp"
            app:civ_border_color="#E2E8F0"/>

        <!-- Content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/txt_notif_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tiêu đề thông báo"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1E293B"/>

            <TextView
                android:id="@+id/txt_notif_sender"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Người gửi: Admin"
                android:textSize="12sp"
                android:textColor="#64748B"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/txt_notif_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nội dung thông báo chi tiết sẽ hiển thị ở đây..."
                android:textSize="13sp"
                android:textColor="#475569"
                android:layout_marginTop="6dp"
                android:lineSpacingExtra="2dp"/>

            <TextView
                android:id="@+id/txt_notif_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10 phút trước"
                android:textSize="11sp"
                android:textColor="#94A3B8"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- Unread Dot -->
        <View
            android:id="@+id/view_unread_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/tab_active_background"
            android:backgroundTint="#EF4444"
            android:visibility="visible"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>