<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="16dp">

    <!-- Thứ 2 (30/03) -->
    <TextView
        android:id="@+id/tv_day_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#E5E7EB"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:text="Thứ 2 (30/03)"
        android:textColor="#111827"
        android:textSize="17sp"
        android:textStyle="bold" />

    <!-- Section Buổi Sáng -->
    <LinearLayout
        android:id="@+id/layout_morning_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">
        <TextView
            android:id="@+id/tv_morning_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="4dp"
            android:text="BUỔI SÁNG (Tiết 1-5)"
            android:textSize="12sp"
            android:textColor="#3B82F6"
            android:textStyle="bold"/>
        <LinearLayout
            android:id="@+id/layout_morning_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </LinearLayout>

    <!-- Section Buổi Chiều -->
    <LinearLayout
        android:id="@+id/layout_afternoon_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">
        <TextView
            android:id="@+id/tv_afternoon_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="4dp"
            android:text="BUỔI CHIỀU (Tiết 6-12)"
            android:textSize="12sp"
            android:textColor="#10B981"
            android:textStyle="bold"/>
        <LinearLayout
            android:id="@+id/layout_afternoon_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </LinearLayout>

</LinearLayout>