<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.appbar.AppBarLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF"
    android:fitsSystemWindows="false"
    app:elevation="0dp">

    <com.google.android.material.appbar.MaterialToolbar
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="0dp"
        app:contentInsetLeft="0dp"
        app:contentInsetStart="0dp"
        app:contentInsetStartWithNavigation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp">

            <!-- Logo Trường -->
            <ImageView
                android:id="@+id/logotruong"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:src="@drawable/logotruong"
                android:scaleType="fitCenter" />

            <!-- Cụm chữ: Tên trường và Mô tả -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="10dp"
                android:paddingEnd="4dp">

                <TextView
                    android:id="@+id/txt_ten_truong"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TRƯỜNG THPT ANH SƠN I"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#1E3A8A"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/txt_sub_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hệ thống thông minh"
                    android:textSize="11sp"
                    android:textColor="#666666" />
            </LinearLayout>

            <!-- Icon Thông báo -->
            <ImageView
                android:id="@+id/btn_bell"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/bell"
                android:layout_marginEnd="12dp"
                android:contentDescription="Notification" />

            <!-- Icon Cài đặt -->
            <ImageView
                android:id="@+id/btn_setting"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/setting"
                android:layout_marginEnd="12dp"
                android:contentDescription="Settings" />

            <!-- Ảnh User tròn -->
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/btn_user"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/anhuser"
                app:civ_border_width="1dp"
                app:civ_border_color="#EEEEEE"/>

        </LinearLayout>

    </com.google.android.material.appbar.MaterialToolbar>

</com.google.android.material.appbar.AppBarLayout>