<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.appbar.AppBarLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF"
    app:elevation="0dp">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        app:contentInsetStart="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">

            <!-- Logo and Name -->
            <ImageView
                android:id="@+id/logotruong"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/logotruong"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/txt_ten_truong"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Anh Sơn I"
                android:textColor="#1E3A8A"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone"/> <!-- Ẩn bớt text nếu màn hình nhỏ -->

            <!-- Hamburger Menu Icon -->
            <ImageView
                android:id="@+id/btn_menu"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_menu"
                app:tint="#666666" />

            <!-- Search Box -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="12dp"
                android:layout_weight="1"
                android:background="@drawable/bg_search_box"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp">

                <EditText
                    android:id="@+id/edt_search"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="Tìm kiếm..."
                    android:textSize="13sp" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_search"
                    app:tint="#999999"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- Thêm lại các icon cũ để tránh lỗi code Java -->
            <ImageView
                android:id="@+id/btn_bell"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/bell"
                app:tint="#666666" />

            <ImageView
                android:id="@+id/btn_setting"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/setting"
                app:tint="#666666" />

            <!-- User profile image -->
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/btn_user"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/anhuser" />

        </LinearLayout>
    </com.google.android.material.appbar.MaterialToolbar>
</com.google.android.material.appbar.AppBarLayout>