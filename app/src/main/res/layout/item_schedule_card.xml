<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="2dp"
    app:cardElevation="1dp"
    app:strokeWidth="0.5dp"
    app:strokeColor="#D1D5DB">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Watermark: Số mờ lớn ở nền (Thứ 2 hiện số 2, Thứ 7 hiện số 7...) -->
        <TextView
            android:id="@+id/tv_watermark"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="10dp"
            android:text="2"
            android:textColor="#F1F5F9"
            android:textSize="120sp"
            android:textStyle="bold"
            android:includeFontPadding="false" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Tên môn học: Font lớn, bôi đậm, căn giữa -->
            <TextView
                android:id="@+id/tv_subject_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tên môn học"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="14dp" />

            <!-- Các thông tin chi tiết với label bôi đậm -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="1dp">
                <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="Tiết: " android:textStyle="bold" android:textColor="#1A1A1A" android:textSize="14sp"/>
                <TextView android:id="@+id/tv_periods" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="6 - 8 (3 tiết)" android:textColor="#1A1A1A" android:textSize="14sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="2dp">
                <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="Địa điểm: " android:textStyle="bold" android:textColor="#1A1A1A" android:textSize="14sp"/>
                <TextView android:id="@+id/tv_location" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Cơ sở 2 - Nhà A5" android:textColor="#1A1A1A" android:textSize="14sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="2dp">
                <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="Hệ đào tạo: " android:textStyle="bold" android:textColor="#1A1A1A" android:textSize="14sp"/>
                <TextView android:id="@+id/tv_training_system" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Hệ Đại học chính quy" android:textColor="#1A1A1A" android:textSize="14sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="2dp">
                <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="Học phần: " android:textStyle="bold" android:textColor="#1A1A1A" android:textSize="14sp"/>
                <TextView android:id="@+id/tv_course" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Tên môn học đầy đủ" android:textColor="#1A1A1A" android:textSize="14sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="2dp">
                <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="Giảng viên: " android:textStyle="bold" android:textColor="#1A1A1A" android:textSize="14sp"/>
                <TextView android:id="@+id/tv_teacher" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Tên giảng viên" android:textColor="#1A1A1A" android:textSize="14sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="2dp">
                <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="Tuần dạy: " android:textStyle="bold" android:textColor="#1A1A1A" android:textSize="14sp"/>
                <TextView android:id="@+id/tv_weeks" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="21 -> 38" android:textColor="#1A1A1A" android:textSize="14sp"/>
            </LinearLayout>

        </LinearLayout>
    </RelativeLayout>
</com.google.android.material.card.MaterialCardView>