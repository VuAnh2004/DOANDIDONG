<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Ảnh nền -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/truong"
        android:contentDescription="@null" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_soft_overlay" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                app:cardBackgroundColor="#D9FFFFFF"
                app:cardCornerRadius="40dp"
                app:cardElevation="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/header_pastel_gradient"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="24dp">

                        <androidx.cardview.widget.CardView
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            app:cardCornerRadius="30dp"
                            app:cardElevation="6dp"
                            app:cardBackgroundColor="#FFFFFF">

                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:layout_gravity="center"
                                android:src="@drawable/logotruong"
                                android:contentDescription="Logo" />
                        </androidx.cardview.widget.CardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingStart="16dp"
                            tools:ignore="RtlSymmetry">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="THPT ANH SƠN I"
                                android:textColor="#FFFFFF"
                                android:textSize="20sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="HỆ THỐNG QUẢN TRỊ THÔNG MINH"
                                android:textColor="#E8EAF6"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Body -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="24dp"
                        android:paddingTop="32dp"
                        android:paddingBottom="40dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ĐẶT LẠI MẬT KHẨU"
                            android:textColor="#6366F1"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:layout_gravity="center"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="24dp"
                            android:gravity="center"
                            android:text="Nhập mã xác nhận từ Email và mật khẩu mới của bạn."
                            android:textColor="#6B7280"
                            android:textSize="14sp" />

                        <!-- Mã xác nhận -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mã xác nhận (Token)"
                            android:textColor="#4B5563"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/input_modern_bg"
                            android:paddingHorizontal="16dp"
                            android:layout_marginBottom="16dp">

                            <EditText
                                android:id="@+id/et_token"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Nhập mã xác nhận"
                                android:background="@null"
                                android:textSize="16sp"
                                android:textColor="#1F2937"
                                android:paddingVertical="14dp"
                                android:inputType="text"
                                android:importantForAutofill="no" />
                        </LinearLayout>

                        <!-- Mật khẩu mới -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mật khẩu mới"
                            android:textColor="#4B5563"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/input_modern_bg"
                            android:paddingHorizontal="16dp"
                            android:layout_marginBottom="16dp">

                            <EditText
                                android:id="@+id/et_new_password"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:hint="Nhập mật khẩu mới"
                                android:background="@null"
                                android:textSize="16sp"
                                android:textColor="#1F2937"
                                android:paddingVertical="14dp"
                                android:inputType="textPassword"
                                android:importantForAutofill="no" />

                            <ImageView
                                android:id="@+id/iv_toggle_new_password"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_eye_off"
                                app:tint="#9CA3AF"
                                android:contentDescription="Hiển thị" />
                        </LinearLayout>

                        <!-- Xác nhận mật khẩu -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Xác nhận mật khẩu mới"
                            android:textColor="#4B5563"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/input_modern_bg"
                            android:paddingHorizontal="16dp">

                            <EditText
                                android:id="@+id/et_confirm_password"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:hint="Xác nhận lại mật khẩu"
                                android:background="@null"
                                android:textSize="16sp"
                                android:textColor="#1F2937"
                                android:paddingVertical="14dp"
                                android:inputType="textPassword"
                                android:importantForAutofill="no" />

                            <ImageView
                                android:id="@+id/iv_toggle_confirm_password"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_eye_off"
                                app:tint="#9CA3AF"
                                android:contentDescription="Hiển thị" />
                        </LinearLayout>

                        <ProgressBar
                            android:id="@+id/loading_progress"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_gravity="center"
                            android:layout_marginTop="16dp"
                            android:visibility="gone"/>

                        <Button
                            android:id="@+id/btn_reset"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginTop="32dp"
                            android:background="@drawable/btn_soft_gradient"
                            android:text="CẬP NHẬT MẬT KHẨU"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </FrameLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
