    <style name="Theme.DOANQLDIEM" parent="Base.Theme.DOANQLDIEM" />

    <!-- Style cho tiêu đề bảng điểm (Header) -->
    <style name="DiemTableHead">
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
    </style>

    <!-- Style cho nội dung bảng điểm (Body) -->
    <style name="DiemTableBody">
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#475569</item>
        <item name="android:textSize">11sp</item>
        <item name="android:gravity">center</item>
    </style>
