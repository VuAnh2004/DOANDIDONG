<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Nền màu đỏ nhạt -->
    <solid android:color="#FEF2F2" />

    <!-- Viền đỏ nhẹ -->
    <stroke
        android:width="1.2dp"
        android:color="#F87171" />

    <!-- Bo góc -->
    <corners android:radius="12dp" />

    <!-- Padding bên trong (tùy chọn) -->
    <padding
        android:left="12dp"
        android:top="10dp"
        android:right="12dp"
        android:bottom="10dp" />

</shape>