@WebServlet("/dashboard")
public class DashboardServlet extends HttpServlet {
    
    @Override
    protected void doGet(HttpServletRequest request, HttpServletResponse response) 
            throws ServletException, IOException {
        
        Connection conn = null;
        PreparedStatement pstmt = null;
        ResultSet rs = null;
        
        try {
            // Kết nối database
            conn = DatabaseConnection.getConnection();
            Gson gson = new Gson();
            
            // Lấy học kỳ hiện tại (giả sử là học kỳ mới nhất đang active)
            int currentSemesterId = getCurrentSemesterId(conn);
            
            // 1. Tổng số học sinh từ QLHocSinh
            pstmt = conn.prepareStatement("SELECT COUNT(*) AS tongHocSinh FROM dbo.QLHocSinh WHERE IsActive = 1");
            rs = pstmt.executeQuery();
            int tongHocSinh = rs.next() ? rs.getInt("tongHocSinh") : 0;
            closeResources(rs, pstmt);
            
            // 2. Tổng số giáo viên từ QLGiaoVien
            pstmt = conn.prepareStatement("SELECT COUNT(*) AS tongGiaoVien FROM dbo.QLGiaoVien WHERE IsActive = 1");
            rs = pstmt.executeQuery();
            int tongGiaoVien = rs.next() ? rs.getInt("tongGiaoVien") : 0;
            closeResources(rs, pstmt);
            
            // 3. Tổng số lớp học từ QLLopHoc
            pstmt = conn.prepareStatement("SELECT COUNT(*) AS tongLopHoc FROM dbo.QLLopHoc WHERE IsActive = 1");
            rs = pstmt.executeQuery();
            int tongLopHoc = rs.next() ? rs.getInt("tongLopHoc") : 0;
            closeResources(rs, pstmt);
            
            // 4. Tổng số môn học từ QLMonHoc
            pstmt = conn.prepareStatement("SELECT COUNT(*) AS tongMonHoc FROM dbo.QLMonHoc WHERE IsActive = 1");
            rs = pstmt.executeQuery();
            int tongMonHoc = rs.next() ? rs.getInt("tongMonHoc") : 0;
            closeResources(rs, pstmt);
            
            // 5. Top 10 lớp có sĩ số cao nhất trong học kỳ hiện tại
            pstmt = conn.prepareStatement(
                "SELECT TOP 10 " +
                "    l.ClassName AS TenLop, " +
                "    COUNT(DISTINCT hslh.StudentID) AS siSo, " +
                "    k.TenKhoi " +  // Thêm thông tin khối nếu có bảng QLKhoi
                "FROM dbo.QLLopHoc l " +
                "LEFT JOIN dbo.QLHocSinhLopHoc hslh ON l.ClassID = hslh.ClassID " +
                "    AND hslh.IsActive = 1 " +
                "    AND hslh.SemesterID = ? " +  // Lọc theo học kỳ
                "LEFT JOIN dbo.QLKhoi k ON l.GradeLevelId = k.KhoiID " +  // JOIN với khối nếu có
                "WHERE l.IsActive = 1 " +
                "GROUP BY l.ClassID, l.ClassName, k.TenKhoi " +
                "ORDER BY siSo DESC"
            );
            pstmt.setInt(1, currentSemesterId);
            rs = pstmt.executeQuery();
            
            List<String> danhSachLop = new ArrayList<>();
            List<Integer> siSoList = new ArrayList<>();
            List<String> khoiList = new ArrayList<>();
            
            while (rs.next()) {
                danhSachLop.add(rs.getString("TenLop"));
                siSoList.add(rs.getInt("siSo"));
                khoiList.add(rs.getString("TenKhoi") != null ? rs.getString("TenKhoi") : "Không xác định");
            }
            closeResources(rs, pstmt);
            
            // 6. Phân bố học lực từ QLDiem trong học kỳ hiện tại
            pstmt = conn.prepareStatement(
                "SELECT " +
                "    COUNT(CASE WHEN d.AverageScore >= 9.0 THEN 1 END) AS XuatSac, " +
                "    COUNT(CASE WHEN d.AverageScore >= 8.0 AND d.AverageScore < 9.0 THEN 1 END) AS Gioi, " +
                "    COUNT(CASE WHEN d.AverageScore >= 6.5 AND d.AverageScore < 8.0 THEN 1 END) AS Kha, " +
                "    COUNT(CASE WHEN d.AverageScore >= 5.0 AND d.AverageScore < 6.5 THEN 1 END) AS TrungBinh, " +
                "    COUNT(CASE WHEN d.AverageScore < 5.0 THEN 1 END) AS Kem " +
                "FROM dbo.QLDiem d " +
                "INNER JOIN dbo.QLHocKy hk ON d.SemesterID = hk.SemesterID " +
                "WHERE d.IsActive = 1 " +
                "    AND d.AverageScore IS NOT NULL " +
                "    AND d.SemesterID = ? " +  // Lọc theo học kỳ
                "    AND hk.IsActive = 1"
            );
            pstmt.setInt(1, currentSemesterId);
            rs = pstmt.executeQuery();
            
            int xuatSac = 0, gioi = 0, kha = 0, trungBinh = 0, kem = 0;
            if (rs.next()) {
                xuatSac = rs.getInt("XuatSac");
                gioi = rs.getInt("Gioi");
                kha = rs.getInt("Kha");
                trungBinh = rs.getInt("TrungBinh");
                kem = rs.getInt("Kem");
            }
            closeResources(rs, pstmt);
            
            // 7. Lấy số học sinh theo giới tính
            pstmt = conn.prepareStatement(
                "SELECT " +
                "    CASE WHEN Gender IS NULL OR Gender = '' THEN 'Không xác định' ELSE Gender END AS Gender, " +
                "    COUNT(*) AS SoLuong " +
                "FROM dbo.QLHocSinh " +
                "WHERE IsActive = 1 " +
                "GROUP BY Gender"
            );
            rs = pstmt.executeQuery();
            
            Map<String, Integer> gioiTinh = new HashMap<>();
            while (rs.next()) {
                gioiTinh.put(rs.getString("Gender"), rs.getInt("SoLuong"));
            }
            closeResources(rs, pstmt);
            
            // 8. Lấy top 5 môn học có điểm trung bình cao nhất
            pstmt = conn.prepareStatement(
                "SELECT TOP 5 " +
                "    m.SubjectName AS TenMonHoc, " +
                "    ROUND(AVG(d.AverageScore), 2) AS DiemTrungBinh, " +
                "    COUNT(d.StudentID) AS SoHocSinh " +
                "FROM dbo.QLDiem d " +
                "INNER JOIN dbo.QLMonHoc m ON d.SubjectID = m.SubjectID " +
                "WHERE d.IsActive = 1 " +
                "    AND m.IsActive = 1 " +
                "    AND d.AverageScore IS NOT NULL " +
                "    AND d.SemesterID = ? " +  // Lọc theo học kỳ
                "GROUP BY m.SubjectID, m.SubjectName " +
                "HAVING COUNT(d.StudentID) > 0 " +
                "ORDER BY DiemTrungBinh DESC"
            );
            pstmt.setInt(1, currentSemesterId);
            rs = pstmt.executeQuery();
            
            List<String> topMonHoc = new ArrayList<>();
            List<Double> diemMonHoc = new ArrayList<>();
            List<Integer> siSoMonHoc = new ArrayList<>();
            
            while (rs.next()) {
                topMonHoc.add(rs.getString("TenMonHoc"));
                diemMonHoc.add(rs.getDouble("DiemTrungBinh"));
                siSoMonHoc.add(rs.getInt("SoHocSinh"));
            }
            closeResources(rs, pstmt);
            
            // 9. Lấy danh sách học kỳ
            pstmt = conn.prepareStatement(
                "SELECT SemesterID, SemesterName FROM dbo.QLHocKy WHERE IsActive = 1 ORDER BY SemesterID"
            );
            rs = pstmt.executeQuery();
            
            List<Map<String, Object>> hocKyList = new ArrayList<>();
            while (rs.next()) {
                Map<String, Object> hocKy = new HashMap<>();
                hocKy.put("id", rs.getInt("SemesterID"));
                hocKy.put("name", rs.getString("SemesterName"));
                hocKyList.add(hocKy);
            }
            closeResources(rs, pstmt);
            
            // 10. Lấy số lượng học sinh theo trạng thái
            pstmt = conn.prepareStatement(
                "SELECT " +
                "    CASE WHEN StatusStudent IS NULL OR StatusStudent = '' THEN 'Không xác định' ELSE StatusStudent END AS Status, " +
                "    COUNT(*) AS SoLuong " +
                "FROM dbo.QLHocSinh " +
                "WHERE IsActive = 1 " +
                "GROUP BY StatusStudent"
            );
            rs = pstmt.executeQuery();
            
            Map<String, Integer> trangThaiHS = new HashMap<>();
            while (rs.next()) {
                trangThaiHS.put(rs.getString("Status"), rs.getInt("SoLuong"));
            }
            closeResources(rs, pstmt);
            
            // 11. Lấy số lượng giáo viên theo trạng thái
            pstmt = conn.prepareStatement(
                "SELECT " +
                "    CASE WHEN StatusTeacher IS NULL OR StatusTeacher = '' THEN 'Không xác định' ELSE StatusTeacher END AS Status, " +
                "    COUNT(*) AS SoLuong " +
                "FROM dbo.QLGiaoVien " +
                "WHERE IsActive = 1 " +
                "GROUP BY StatusTeacher"
            );
            rs = pstmt.executeQuery();
            
            Map<String, Integer> trangThaiGV = new HashMap<>();
            while (rs.next()) {
                trangThaiGV.put(rs.getString("Status"), rs.getInt("SoLuong"));
            }
            closeResources(rs, pstmt);
            
            // Set attribute
            request.setAttribute("totalStudents", tongHocSinh);
            request.setAttribute("totalTeachers", tongGiaoVien);
            request.setAttribute("totalClasses", tongLopHoc);
            request.setAttribute("totalSubjects", tongMonHoc);
            request.setAttribute("currentSemesterId", currentSemesterId);
            
            // Chuyển danh sách thành JSON
            request.setAttribute("classNames", gson.toJson(danhSachLop));
            request.setAttribute("studentCounts", gson.toJson(siSoList));
            request.setAttribute("khoiList", gson.toJson(khoiList));
            
            // Dữ liệu học lực
            request.setAttribute("xuatSac", xuatSac);
            request.setAttribute("gioi", gioi);
            request.setAttribute("kha", kha);
            request.setAttribute("trungBinh", trungBinh);
            request.setAttribute("kem", kem);
            
            // Phổ điểm
            int[] phoDiem = {kem, trungBinh, kha, gioi, xuatSac};
            request.setAttribute("scoreData", gson.toJson(phoDiem));
            
            // Dữ liệu giới tính
            request.setAttribute("nam", gioiTinh.getOrDefault("Nam", 0));
            request.setAttribute("nu", gioiTinh.getOrDefault("Nữ", 0));
            request.setAttribute("khac", gioiTinh.getOrDefault("Khác", 0) + 
                gioiTinh.getOrDefault("Không xác định", 0));
            
            // Top môn học
            request.setAttribute("topMonHoc", gson.toJson(topMonHoc));
            request.setAttribute("diemMonHoc", gson.toJson(diemMonHoc));
            request.setAttribute("siSoMonHoc", gson.toJson(siSoMonHoc));
            
            // Học kỳ
            request.setAttribute("hocKyList", gson.toJson(hocKyList));
            
            // Trạng thái học sinh
            request.setAttribute("trangThaiHS", gson.toJson(trangThaiHS));
            request.setAttribute("trangThaiGV", gson.toJson(trangThaiGV));
            
            // Chuyển đến JSP
            request.getRequestDispatcher("/dashboard.jsp").forward(request, response);
            
        } catch (SQLException e) {
            e.printStackTrace();
            request.setAttribute("error", "Lỗi kết nối database: " + e.getMessage());
            request.getRequestDispatcher("/error.jsp").forward(request, response);
        } finally {
            closeResources(null, null, conn);
        }
    }
    
    private int getCurrentSemesterId(Connection conn) throws SQLException {
        PreparedStatement pstmt = null;
        ResultSet rs = null;
        try {
            // Lấy học kỳ active mới nhất
            pstmt = conn.prepareStatement(
                "SELECT TOP 1 SemesterID FROM dbo.QLHocKy WHERE IsActive = 1 ORDER BY SemesterID DESC"
            );
            rs = pstmt.executeQuery();
            return rs.next() ? rs.getInt("SemesterID") : 1; // Mặc định là 1 nếu không có
        } finally {
            closeResources(rs, pstmt);
        }
    }
    
    private void closeResources(ResultSet rs, PreparedStatement pstmt) {
        try {
            if (rs != null) rs.close();
            if (pstmt != null) pstmt.close();
        } catch (SQLException e) {
            e.printStackTrace();
        }
    }
    
    private void closeResources(ResultSet rs, PreparedStatement pstmt, Connection conn) {
        closeResources(rs, pstmt);
        try {
            if (conn != null) conn.close();
        } catch (SQLException e) {
            e.printStackTrace();
        }
    }
}
